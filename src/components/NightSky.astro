---
/**
 * NightSky.astro — the fixed, full-viewport, decorative scene host.
 *
 * Layer 0 (starfield + Milky Way, canvas, generated by nightsky/starfield.ts)
 * blits into #nightsky-canvas via scene.ts's engine. Layer 1 (this component's
 * own static markup) is the hand-authored camper silhouette + its single
 * copper glow — pure DOM/CSS, never touches the rAF loop (05-UI-SPEC.md
 * "Scene Composition & Layering Contract", Layer 1). Layer 2 (twinkle,
 * fireflies, constellation firing — 05-04/05-05) draws on the same visible
 * canvas as Layer 0, on top of its blit.
 *
 * Stacking: position:fixed, inset:0, z-index:-1 — deliberately NEGATIVE,
 * not 0. `.deck` only becomes position:fixed (z-index:1) once deck.ts adds
 * `html.deck-active` (see PanelDeck.astro); without that class (the DECK-07
 * no-JS/init-failure fallback), the page's content is plain static in-flow
 * markup, and CSS's painting order places a POSITIVE/zero-z-index
 * `position:fixed` element ABOVE static in-flow content, not below it. A
 * negative z-index paints before (behind) all in-flow content in every
 * mode, deck-active or not, while still trivially sitting below `.deck`'s
 * z-index:1 whenever that class *is* present. (Rule 2 — this is required
 * for correct behavior in the no-JS fallback, not just the deck-active
 * happy path the plan's screenshot verification exercises.)
 *
 * Non-interactive + decorative: pointer-events:none and aria-hidden="true"
 * on the host (pointer-events is an inherited property, so canvas + svg
 * both inherit `none`; both also carry their own explicit rule below so the
 * contract holds even if markup nesting ever changes — 05-RESEARCH.md
 * Pattern 5).
 *
 * The trailing bare script tag below (no attributes — same Astro TS/import
 * bundling seam Figure01.astro uses, 02-RESEARCH.md Pattern 1) boots the
 * scene engine exactly once on load: `initNightSky(host)` from
 * nightsky/scene.ts (05-04) owns the SINGLE animation-frame driver
 * (Layer-0 blit + Layer-2 twinkle/fireflies), the debounced resize regen,
 * and the pause state machine (tab-hidden / fig-01-active via the
 * `nightsky:panel-change` document event / prefers-reduced-motion static
 * frame). This superseded 05-03's interim one-time generate+blit
 * bootstrap — there is exactly ONE boot path for the scene. No
 * ClientRouter is in use (plain MPA navigation), so a plain load-time
 * init with a retained teardown is correct; the teardown exists for
 * symmetry with the codebase's init contract, not for a re-init path.
 *
 * 07-03 (IMG-01/IMG-02): the real Milky-Way photo is delivered as a plain
 * <picture>/<img> — the FIRST child of the host, painting at the BOTTOM by
 * DOM order (no new z-index values; 07-RESEARCH.md §4.3). It is never
 * drawn into any canvas (Canvas2D is 8-bit — would defeat the 10-bit AVIF
 * encode, PITFALLS.md) and renders identically with zero JS (no-JS classic
 * mode), which is why the LQIP-to-full fade below is a pure CSS keyframe
 * that ENDS at opacity:1 — never a load-event-gated opacity. The LQIP is
 * read at build time from build-sky.mjs's committed output so that script
 * stays the single source of truth (07-RESEARCH.md §4.2).
 */
import { readFileSync } from "node:fs";
import { join } from "node:path";

// Resolved from the project root (astro build/dev's cwd), NOT
// import.meta.url — the bundled prerender chunk relocates to
// dist/.prerender/chunks, which breaks source-relative URL resolution.
const LQIP = readFileSync(
  join(process.cwd(), "public/sky/milky-way-lqip.txt"),
  "utf8"
).trim();
---

<div class="nightsky-host" aria-hidden="true">
  <div class="sky-photo" style={`background-image: url('${LQIP}')`}>
    <picture>
      <source
        type="image/avif"
        srcset="/sky/milky-way-1920.avif 1920w, /sky/milky-way-2560.avif 2560w"
        sizes="100vw"
      />
      <source
        type="image/webp"
        srcset="/sky/milky-way-1920.webp 1920w, /sky/milky-way-2560.webp 2560w"
        sizes="100vw"
      />
      <img
        src="/sky/milky-way-1920.avif"
        alt=""
        role="presentation"
        fetchpriority="high"
        loading="eager"
        decoding="async"
      />
    </picture>
  </div>

  <canvas id="nightsky-canvas"></canvas>

  <div class="camper">
    <svg
      class="camper-svg"
      viewBox="0 0 200 110"
      preserveAspectRatio="xMidYMax meet"
      aria-hidden="true"
    >
      <!-- Body: rounded-rect profile, filled with the deepest sky tone so it
           reads as a pure silhouette against the lighter horizon gradient
           directly above it (never a second/third fill color). -->
      <rect class="camper-body" x="18" y="34" width="162" height="56" rx="10" />
      <!-- Wheel: single arc, same silhouette fill. -->
      <circle class="camper-wheel" cx="150" cy="94" r="13" />
      <!-- Window/ember: the ONE warm note — var(--accent), never a second
           accent element anywhere else in the scene (05-UI-SPEC.md Color). -->
      <rect class="camper-window" x="128" y="49" width="22" height="17" rx="3" />
    </svg>
    <div class="camper-glow"></div>
  </div>
</div>

<script>
  import { initNightSky } from "../lib/nightsky/scene";

  const host = document.querySelector<HTMLElement>(".nightsky-host");
  // Retained teardown — the single boot path for the whole scene engine
  // (no re-init path exists without ClientRouter; held for the init
  // contract's symmetry and any future lifecycle need).
  const teardownNightSky = host ? initNightSky(host) : null;
  void teardownNightSky;
</script>

<style>
  .nightsky-host {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
  }

  /* 07-03 photo delivery — all sizing present before first paint (never
     JS-injected): the host is position:fixed and never in flow, so the
     photo's box is structurally zero-CLS (07-RESEARCH.md §4.2). The LQIP
     data URI paints as this wrapper's background the instant HTML arrives;
     background-color var(--bg) is the failed-load degradation (plain --bg,
     never a broken-image glyph — 07-UI-SPEC error-state). */
  .sky-photo {
    background-color: var(--bg);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .sky-photo,
  .sky-photo picture,
  .sky-photo img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .sky-photo img {
    object-fit: cover;
    /* Reference desktop tier (1024–1799px): band core lands in the right
       margin per the 07-UI-SPEC placement table. */
    object-position: 72% 38%;
    /* LQIP-to-full fade — a NO-JS-SAFE CSS keyframe (400ms, deck.css's own
       cubic-bezier(0.16,1,0.3,1)) that ENDS at opacity:1, so the photo is
       fully visible without any script (IMG-02 hard gate). The LQIP
       wrapper background sits behind it throughout. If this fade ever
       regresses LCP past budget at the 07-04 checkpoint, the fade yields
       (fallback: LQIP background with no fade — 07-RESEARCH.md §4.2). */
    animation: sky-photo-fade 400ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes sky-photo-fade {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  /* Object-position responsive ladder (07-UI-SPEC), single master served
     via object-fit:cover. NOTE — the <640px tier deliberately deviates
     from the UI-SPEC's 12% 25%: the committed winner master (A-core-t20,
     07-SPIKE-BANDING.md) carries band glow in its upper-left; its genuinely
     quiet window is the LOWER-left (seam-faded) region, so the narrow tier
     anchors at 10% 70% instead (Rule 2 deviation, measured rationale in
     the spike's "Mobile object-position note"). */
  @media (max-width: 639px) {
    .sky-photo img {
      object-position: 10% 70%;
    }
  }

  @media (min-width: 640px) and (max-width: 1023px) {
    .sky-photo img {
      object-position: 55% 32%;
    }
  }

  @media (min-width: 1800px) {
    .sky-photo img {
      object-position: 78% 34%;
    }
  }

  /* Reduced motion: stop, don't dampen (07-UI-SPEC / PITFALLS.md Pitfall
     4) — the photo appears instantly at full opacity, no fade. */
  @media (prefers-reduced-motion: reduce) {
    .sky-photo img {
      animation: none;
      opacity: 1;
    }
  }

  #nightsky-canvas {
    display: block;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  /* Camper container — anchored bottom-left, base sitting on the 15%-from-
     bottom horizon line (05-UI-SPEC.md "Scene composition geometry"). Width
     clamps between 160px and 260px (16vw), anchor x within 0.06-0.22 of
     viewport width. */
  .camper {
    position: absolute;
    left: 8vw;
    bottom: 15%;
    width: clamp(160px, 16vw, 260px);
    aspect-ratio: 200 / 110;
    pointer-events: none;
  }

  .camper-svg {
    display: block;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .camper-body,
  .camper-wheel {
    fill: var(--sky-zenith);
  }

  .camper-window {
    fill: var(--accent);
  }

  /* The single copper glow — CSS radial-gradient, never shadowBlur/filter:
     blur() (STACK.md "What NOT to Use", 05-RESEARCH.md Pattern 5). Radius
     40-56px (diameter ~96px), peak alpha ~0.55, centered on the window's
     normalized position within the camper's 200x110 viewBox (140,63 ->
     70%,57.3%). Reads on top of the SVG (window overlaps the glow's core),
     so no new stacking is needed beyond normal DOM order. */
  .camper-glow {
    position: absolute;
    left: 70%;
    top: 57.3%;
    width: 96px;
    height: 96px;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    pointer-events: none;
    background: radial-gradient(
      circle,
      rgb(from var(--accent) r g b / 0.55) 0%,
      rgb(from var(--accent) r g b / 0.22) 45%,
      rgb(from var(--accent) r g b / 0) 72%
    );
    animation: camper-glow-pulse 5s ease-in-out infinite;
  }

  @keyframes camper-glow-pulse {
    0%,
    100% {
      opacity: 0.7;
    }
    50% {
      opacity: 1;
    }
  }

  /* Reduced motion: hold at the pulse's midpoint rather than either
     extreme (05-UI-SPEC.md Reduced-motion contract, Layer 1 row). */
  @media (prefers-reduced-motion: reduce) {
    .camper-glow {
      animation: none;
      opacity: 0.85;
    }
  }
</style>
