---
/**
 * Panel.astro — thin full-viewport panel wrapper.
 *
 * Renders every deck panel's content root. Deliberately a <div>, not a
 * <section>, to avoid nested landmark/id semantics (each v1 section
 * component underneath already owns its own semantics). Carries
 * `data-panel-id` UNCONDITIONALLY — deck.ts (plan 04-02) keys the
 * change-event `detail.id` and focus target off `.panel`/`data-panel-id`,
 * never off the DOM `id` attribute, because `id` is conditionally omitted
 * (see `emitId` below) to avoid a duplicate id when the wrapped section
 * already renders its own id (e.g. ContactSection's id="contact").
 *
 * All layout/positioning/hiding CSS lives in src/styles/deck.css, scoped
 * under html.deck-active — this component ships zero layout styling of its
 * own so the v1 no-JS page renders these as plain in-flow <div>s.
 */
interface Props {
  id: string;
  label?: string;
  emitId?: boolean;
  /**
   * Server-rendered initial deck state (2026-07-19 sky-visibility fix,
   * 10-UI-REVIEW warning "pre-hydration ghost flash"): the built HTML now
   * ships data-state on every panel (hero "active", the rest "inactive")
   * so the first paint under PanelDeck.astro's speculative pre-paint
   * `.deck-active` add shows ONE panel instead of all 7 stacked. deck.ts's
   * applyPanelStates keeps full runtime ownership (it overwrites these on
   * init, synchronously, before adding .deck-active itself on non-hero
   * deep links). Every [data-state] rule in deck.css is scoped under
   * html.deck-active, so the no-JS/classic page ignores the attribute
   * entirely — all content stays visible without script (DECK-07 floor).
   */
  initialState?: "active" | "inactive";
}

const { id, label, emitId = true, initialState = "inactive" } = Astro.props;
// `label` is accepted (and passed by every index.astro call site per the
// UI-SPEC copywriting contract) but not rendered by this wrapper — the
// manifest-driven DeckIndex.astro is the sole consumer of panel labels.
void label;
---

<div
  class="panel"
  data-panel-id={id}
  id={emitId ? id : undefined}
  tabindex="-1"
  data-state={initialState}
>
  {/* .panel-card — the content-card surface (2026-07-19 sky-visibility fix,
      .planning/10-UI-REVIEW.md remediation 1a): the glass system's
      backdrop-filter + fills attach HERE (deck.css §8), never to the
      full-viewport .panel, so the night-sky scene renders crystal-clear in
      the margins/strips outside the ~880px text column. Unstyled outside
      deck.css's html.deck-active / html.classic-active scopes — the no-JS
      page renders it as a plain pass-through <div>. */}
  <div class="panel-card">
    <slot />
  </div>
</div>
