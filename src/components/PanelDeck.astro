---
/**
 * PanelDeck.astro — deck shell: wraps the panel stack + DeckIndex, and boots
 * the deck.ts controller.
 *
 * Imports deck.css in frontmatter so the deck layout stylesheet only bundles
 * on pages that actually render a deck (currently just index.astro). Every
 * rule in deck.css is scoped under html.deck-active, so importing it here
 * has zero visual effect until deck.ts adds that class.
 *
 * Guarded pre-paint activation (04-03, "fix now, guarded" human decision —
 * eliminates the CLS=1 first-paint reflow documented in lighthouse-scores.md
 * "Known Issue" while preserving the DECK-07 fallback guarantee):
 *
 * 1. The `is:inline` script below runs synchronously, in document order,
 *    BEFORE the .deck markup — so it executes during initial HTML parsing,
 *    before first paint. It speculatively adds `.deck-active` to <html>
 *    ONLY when both synchronous preconditions hold: no `deck-view-
 *    preference: classic` in localStorage (the same strict check deck.ts's
 *    own init uses — the key/value are duplicated here on purpose, since an
 *    is:inline script can't import deck.ts's constants; keep both in sync
 *    if either ever changes) AND `location.hash` is empty or `#hero`.
 *    Non-hero deep links are deliberately left unguarded — deck.ts's own
 *    synchronous hash resolution (before it adds the class itself) already
 *    paints the correct panel first, so pre-applying here would risk a
 *    flash of the wrong panel. Lighthouse audits `/` (no hash), so this is
 *    the path that matters for the CLS metric.
 * 2. A ~2.5s watchdog (armed only when the class was speculatively added)
 *    removes it again if `html[data-deck-ready]` never appears — covering
 *    the "module never executes" case (blocked, network failure, disabled
 *    JS entirely; is:inline scripts don't run at all with JS disabled, so
 *    nothing is ever added and this branch never even arms).
 * 3. The bundled module boot script below closes the remaining gap: if
 *    `.deck` is missing or `initDeck()` throws, it now explicitly removes
 *    `.deck-active` too, since the class may already be present from the
 *    speculative pre-paint add — so any init failure still falls back to
 *    the v1 scrolling layout (DECK-07), even with pre-paint activation.
 * 4. `deck.ts` itself sets `data-deck-ready="true"` on <html> as the very
 *    last step of a successful init (both modes) and defensively removes a
 *    stray speculative `.deck-active` if the resolved preference actually
 *    turns out to be classic — see deck.ts's own comments.
 */
import DeckIndex from "./DeckIndex.astro";
import "../styles/deck.css";
---

<script is:inline>
  (function () {
    try {
      var htmlEl = document.documentElement;
      var pref = localStorage.getItem("deck-view-preference");
      var hash = location.hash;
      if (pref !== "classic" && (hash === "" || hash === "#hero")) {
        htmlEl.classList.add("deck-active");
        setTimeout(function () {
          try {
            if (htmlEl.dataset.deckReady !== "true") {
              htmlEl.classList.remove("deck-active");
            }
          } catch (e) {}
        }, 2500);
      }
    } catch (e) {}
  })();
</script>

<div class="deck">
  <slot />
</div>
{/* DeckIndex renders OUTSIDE .deck since Phase 8 (08-02): .deck is
    position:fixed z-index:1 — a stacking context that trapped the fixed
    index pill / hint / mode links (z-index 21) BENEATH the z-index 20
    header/footer, so the footer's new backdrop-filter glass smeared the
    pill into its backdrop (invisible pre-glass because the footer painted
    nothing). As a root-level sibling, z-index 21 now genuinely beats the
    chrome's 20 — the pill paints (and hit-tests) above the footer glass.
    deck.ts locates these hooks document-wide (ids/classes are unique). */}
<DeckIndex />

<script>
  import { initDeck } from "../lib/nightsky/deck";

  const root = document.querySelector<HTMLElement>(".deck");
  try {
    if (root) {
      initDeck(root);
    } else {
      throw new Error("PanelDeck: .deck root not found");
    }
  } catch {
    // .deck-active may already be present from the pre-paint speculative
    // add above — remove it defensively so init failure always falls back
    // to the v1 scrolling layout (DECK-07 progressive-enhancement floor).
    document.documentElement.classList.remove("deck-active");
  }
</script>
