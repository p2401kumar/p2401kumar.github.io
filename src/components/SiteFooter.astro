---
/**
 * SiteFooter.astro — status line + live Seattle clock + photo credit.
 *
 * Ports the approved prototype's `<footer>` block verbatim (markup,
 * spacing, type) plus the `tick()` clock script as a plain inline module
 * script (no hydration framework — 01-RESEARCH.md Pattern 2).
 *
 * Phase 7 (IMG-04): the footer is now a 2-line flex column — the original
 * status/clock row wrapped in `.footer-row`, plus the CC BY 4.0 photo
 * credit line below it (07-UI-SPEC.md "Credit Line"). Credit copy is
 * LOCKED verbatim (07-CONTEXT.md honesty gate, full unabridged form):
 *
 *   Sky: NOIRLab/NSF/AURA/E. Slawik/M. Zamani, CC BY 4.0
 *
 * NOIRLab links to the noirlab.edu noirlab2430b image page and CC BY 4.0
 * links to the Creative Commons by/4.0 license page (hrefs below) —
 * both target=_blank with rel="noopener noreferrer" (threat T-07-06,
 * reverse-tabnabbing mitigation). The credit renders UNCONDITIONALLY on
 * every page sharing this footer (07-RESEARCH.md pitfall 9) and in BOTH
 * modes: deck (fixed chrome) and classic (normal flow).
 *
 * Threat model T-01-09 (accept): trivial read-only DOM script, no external
 * input, no eval, no network — no attack surface.
 */
---

<footer>
  <div class="footer-row">
    <span class="st"><i></i>all systems operational</span>
    <span id="clock">seattle —:—</span>
  </div>
  <p class="credit">
    Sky: <a
      href="https://noirlab.edu/public/images/noirlab2430b/"
      target="_blank"
      rel="noopener noreferrer">NOIRLab</a>/NSF/AURA/E. Slawik/M. Zamani, <a
      href="https://creativecommons.org/licenses/by/4.0/"
      target="_blank"
      rel="noopener noreferrer">CC BY 4.0</a>
  </p>
</footer>

<script>
  function tick() {
    const clockEl = document.getElementById("clock");
    if (!clockEl) return;
    const time = new Intl.DateTimeFormat("en-US", {
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
      timeZone: "America/Los_Angeles",
    }).format(new Date());
    clockEl.textContent = `seattle ${time}`;
  }
  tick();
  setInterval(tick, 30000);
</script>

<style>
  footer {
    display: flex;
    flex-direction: column;
    gap: 8px; /* spacing-scale "xs" (07-UI-SPEC Credit Line) */
    padding: 48px 0 40px;
    border-top: 1px solid var(--hair);
    margin-top: 40px;
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--faint);
  }

  .footer-row {
    display: flex;
    justify-content: space-between;
  }

  .st i {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--good);
    margin-right: 7px;
    vertical-align: 1px;
  }

  /* Photo credit (IMG-04) — same mono/11.5px as the status line,
     left-aligned ragged-left like the row above (never centered). */
  .credit {
    margin: 0;
    font-family: var(--mono);
    font-size: 11.5px;
    line-height: 1.4;
    color: var(--faint);
  }

  /* Site-wide link pattern (global.css + SiteHeader nav precedent):
     --dim at rest / --ink on hover, hairline underline that warms to
     --accent on hover. Not a new pattern. */
  .credit a {
    color: var(--dim);
    border-bottom: 1px solid var(--hair2);
  }

  .credit a:hover {
    color: var(--ink);
    border-color: var(--accent);
  }
</style>
