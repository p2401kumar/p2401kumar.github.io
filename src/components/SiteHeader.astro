---
/**
 * SiteHeader.astro — mono identity + nav.
 *
 * Ports the approved prototype's `<header>` block verbatim (markup, spacing,
 * type). Identity/location sourced from `profile`; nav targets work/résumé/
 * contact per 01-UI-SPEC.md's Copywriting Contract (not the prototype's
 * original work/notes/résumé draft).
 */
import { profile } from "../data/profile";
---

<header>
  <div class="id"><b>{profile.name}</b> · {profile.location}</div>
  <nav>
    <a href="#systems">work</a>
    <a href={profile.links.resume.href}>résumé</a>
    <a href="#contact">contact</a>
  </nav>
</header>

<style>
  header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 30px 0 0;
  }

  .id {
    font-family: var(--mono);
    font-size: 12.5px;
    color: var(--dim);
    letter-spacing: 0.04em;
  }

  .id b {
    color: var(--ink);
    font-weight: 600;
  }

  nav {
    display: flex;
    gap: 22px;
    font-family: var(--mono);
    font-size: 12.5px;
  }

  nav a {
    color: var(--dim);
    border: none;
  }

  nav a:hover {
    color: var(--ink);
  }

  /* Glass chrome (Phase 8, GLS-01) — home-scoped under body.has-sky
     (08-RESEARCH.md Pattern 2): /work/* and /404 never set the class, so
     NO rule below matches there and the header renders exactly as today
     (it has no background property at all — true zero visual diff, not a
     solid fallback). Same reasoning covers @supports-absent and
     prefers-reduced-transparency:reduce: no rule matches, today's look. */
  @supports (backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px)) {
    @media (prefers-reduced-transparency: no-preference) {
      body.has-sky header {
        background: var(--glass-bg-chrome);
        -webkit-backdrop-filter: blur(var(--glass-blur-chrome)) saturate(var(--glass-saturate-chrome)) brightness(var(--glass-brightness-chrome));
        backdrop-filter: blur(var(--glass-blur-chrome)) saturate(var(--glass-saturate-chrome)) brightness(var(--glass-brightness-chrome));
        border-top: 1px solid var(--glass-edge);
      }
    }
  }
</style>
