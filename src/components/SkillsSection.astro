---
/**
 * SkillsSection.astro — "skills" (prose intro + grouped mono tags).
 *
 * Explicitly avoids the skill-bar/logo-wall anti-pattern (PROJECT.md
 * Out of Scope): no proficiency levels, no percentages, no logo images —
 * just quiet mono tags grouped under a label. Sourced from `skillsIntro`
 * and `skillGroups` (src/data/skills.ts).
 */
import { skillsIntro, skillGroups } from "../data/skills";
---

<section class="skills">
  <h2>skills</h2>
  <p class="intro">{skillsIntro}</p>
  {
    skillGroups.map((group) => (
      <div class="group">
        <span class="label">{group.label}</span>
        <div class="tags">
          {group.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </div>
    ))
  }
</section>

<style>
  .skills {
    padding: 64px 0 20px;
  }

  .skills h2 {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dim);
    font-weight: 500;
    margin: 0 0 10px;
  }

  .intro {
    max-width: 58ch;
    font-family: var(--sans);
    font-size: 15px;
    color: var(--body);
    margin: 0 0 22px;
  }

  .group {
    padding: 14px 10px;
    margin: 0 -10px;
    border-top: 1px solid var(--hair);
  }

  .group .label {
    display: block;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--faint);
    margin: 0 0 8px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag {
    font-family: var(--mono);
    font-size: 12.5px;
    color: var(--ink);
    background: var(--panel2);
    border: 1px solid var(--hair2);
    border-radius: 6px;
    padding: 4px 9px;
  }
</style>
