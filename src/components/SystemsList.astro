---
/**
 * SystemsList.astro — "selected systems" (4 rows, 640px responsive).
 *
 * Ports the approved prototype's `.work` section verbatim (markup, spacing,
 * type, 640px collapse — PLAT-05). Rows are mapped from `systems`
 * (src/data/systems.ts), not hardcoded. No case-study links yet (Phase 3).
 */
import { systems } from "../data/systems";
---

<section class="work" id="work">
  <h2>selected systems</h2>
  {
    systems.map((entry) => (
      <div class="row">
        <span class="yr">{entry.year}</span>
        <span>
          <span class="nm">{entry.name}</span>
          <span class="ds">{entry.description}</span>
        </span>
        <span class="mt">{entry.metric}</span>
      </div>
    ))
  }
</section>

<style>
  .work {
    padding: 64px 0 20px;
  }

  .work h2 {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dim);
    font-weight: 500;
    margin: 0 0 10px;
  }

  .row {
    display: grid;
    grid-template-columns: 64px 1fr auto;
    gap: 18px;
    align-items: baseline;
    padding: 14px 10px;
    margin: 0 -10px;
    border-radius: 8px;
    border-top: 1px solid var(--hair);
    transition: background 0.15s;
  }

  .row:hover {
    background: var(--panel2);
  }

  .row .yr {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--faint);
  }

  .row .nm {
    font-family: var(--mono);
    font-size: 13.5px;
    color: var(--ink);
  }

  .row .ds {
    display: block;
    font-family: var(--sans);
    font-size: 13.5px;
    color: var(--dim);
    margin-top: 3px;
  }

  .row .mt {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--accent);
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .row {
      grid-template-columns: 52px 1fr;
    }

    .row .mt {
      display: none;
    }
  }
</style>
