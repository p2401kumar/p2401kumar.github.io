---
/**
 * SystemsList.astro — "selected systems" (4 rows, 640px responsive).
 *
 * Ports the approved prototype's `.work` section verbatim (markup, spacing,
 * type, 640px collapse — PLAT-05). Rows are mapped from `systems`
 * (src/data/systems.ts), not hardcoded. The 2 rows with a matching
 * case-study entry (dynamodb/cellularization, elb/auto-weight-away) become
 * links into /work/{slug}; the linkage is derived from the `case-studies`
 * collection (systemId -> entry.id), not a hardcoded slug list, so a new
 * case-study entry auto-links its row.
 */
import { getCollection } from "astro:content";
import { systems } from "../data/systems";

const caseStudies = await getCollection("case-studies");
const slugsBySystemId = new Map(
  caseStudies.map((entry) => [entry.data.systemId, entry.id]),
);
---

<section class="work" id="work">
  <h2>selected systems</h2>
  {
    systems.map((entry) => {
      const slug = slugsBySystemId.get(entry.name);
      const row = (
        <>
          <span class="yr">{entry.year}</span>
          <span>
            <span class="nm">{entry.name}</span>
            <span class="ds">{entry.description}</span>
          </span>
          <span class="mt">{entry.metric}</span>
        </>
      );
      return slug ? (
        <a class="row" href={`/work/${slug}`}>
          {row}
        </a>
      ) : (
        <div class="row">{row}</div>
      );
    })
  }
</section>

<style>
  .work {
    padding: 64px 0 20px;
  }

  .work h2 {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dim);
    font-weight: 500;
    margin: 0 0 10px;
  }

  .row {
    display: grid;
    grid-template-columns: 64px 1fr auto;
    gap: 18px;
    align-items: baseline;
    padding: 14px 10px;
    margin: 0 -10px;
    border-radius: 8px;
    border-top: 1px solid var(--hair);
    transition: background 0.15s;
  }

  .row:hover {
    background: var(--panel2);
  }

  /* The 2 linked rows are now <a class="row">, not <div class="row"> — reset
     the global `a` underline/color so the row-hover panel2 background stays
     the only hover affordance (no competing underline across the row). */
  a.row {
    color: inherit;
    border-bottom: none;
  }

  a.row:hover {
    border-color: transparent;
  }

  .row .yr {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--faint);
  }

  .row .nm {
    font-family: var(--mono);
    font-size: 13.5px;
    color: var(--ink);
  }

  .row .ds {
    display: block;
    font-family: var(--sans);
    font-size: 13.5px;
    color: var(--dim);
    margin-top: 3px;
  }

  .row .mt {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--accent);
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .row {
      grid-template-columns: 52px 1fr;
    }

    .row .mt {
      display: none;
    }
  }
</style>
