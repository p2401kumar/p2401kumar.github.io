---
/**
 * BaseLayout.astro — the single site shell.
 *
 * head/meta/favicon, imports the three stylesheets exactly once (one-way
 * token flow — ARCHITECTURE.md "Internal Boundaries"), preloads both
 * self-hosted fonts, and exposes a single slot element every page fills.
 *
 * SEO/OpenGraph/twitter meta (title/description/canonical/OG/twitter:card)
 * is delegated to the SEO partial (PLAT-06, Phase 3) so every page inherits
 * full meta coverage from this one shell.
 */
import "../styles/tokens.css";
import "../styles/fonts.css";
import "../styles/global.css";
import SEO from "../components/SEO.astro";

interface Props {
  title?: string;
  description?: string;
  /** Phase 8 (GLS-01): pages rendering the night-sky scene pass hasSky to
   *  emit body.has-sky — the class that gates ALL shared-chrome glass
   *  (SiteHeader/SiteFooter). /work/* and /404 pass nothing, so their
   *  chrome renders exactly as today — zero-leak by construction. */
  hasSky?: boolean;
}

const {
  title = "Prateek Kumar — distributed systems, cloud, applied ai",
  description = "SDE 2 at Microsoft, on Azure's data platform. Previously cellularized DynamoDB's US-EAST-1 region at AWS and built the SmartThings notifications platform at Samsung.",
  hasSky = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEO title={title} description={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Above-the-fold, LCP-relevant font preloads (PLAT-04) -->
    <link
      rel="preload"
      href="/fonts/source-serif-4-latin-500-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/cascadia-code-latin-400-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Page-specific head injections (07-03: index.astro passes the sky
         photo's LCP preload here; work/[slug].astro and 404.astro pass
         nothing and are unaffected). Placed AFTER the font preloads so the
         fonts keep first position in the preload scanner's queue. -->
    <slot name="head" />
  </head>
  <body class={hasSky ? "has-sky" : undefined}>
    <slot />
  </body>
</html>
