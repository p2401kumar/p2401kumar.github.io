---
/**
 * 404.astro — factual error page, matching the site's no-adjective voice.
 *
 * No apology copy, no humor (01-UI-SPEC.md "Error state (404 page)").
 */
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Prateek Kumar">
  <div class="page">
    <div class="notfound">
      <p class="code">404</p>
      <p class="msg">this route doesn't exist.</p>
      <a href="/">back to work →</a>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 clamp(18px, 4vw, 32px);
  }

  .notfound {
    padding: 120px 0;
  }

  .code {
    font-family: var(--mono);
    font-size: 13px;
    letter-spacing: 0.18em;
    color: var(--dim);
    margin: 0 0 12px;
  }

  .msg {
    font-family: var(--serif);
    font-size: clamp(22px, 3vw, 30px);
    color: var(--ink);
    margin: 0 0 22px;
  }

  .notfound a {
    font-family: var(--mono);
    font-size: 13px;
    border-bottom: 1px solid var(--hair2);
  }

  .notfound a:hover {
    border-color: var(--accent);
  }
</style>
