---
/**
 * index.astro — the single-scroll home page.
 *
 * Composes BaseLayout with the full editorial shell + content sections in
 * the locked order (01-CONTEXT.md "Page structure"). Fig. 01 renders
 * between Hero and SystemsList (Phase 2, plan 02-04).
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import NightSky from "../components/NightSky.astro";
import SiteHeader from "../components/SiteHeader.astro";
import PanelDeck from "../components/PanelDeck.astro";
import Panel from "../components/Panel.astro";
import Hero from "../components/Hero.astro";
import Figure01 from "../components/Figure01.astro";
import SystemsList from "../components/SystemsList.astro";
import ExperienceSection from "../components/ExperienceSection.astro";
import PatentsSection from "../components/PatentsSection.astro";
import SkillsSection from "../components/SkillsSection.astro";
import ContactSection from "../components/ContactSection.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout hasSky>
  {/* Sky-photo LCP preload (07-03, IMG-02): imagesrcset/imagesizes MUST
      byte-for-byte mirror NightSky.astro's avif <source> srcset/sizes —
      any mismatch double-fetches (07-RESEARCH.md pitfall 2). */}
  <link
    slot="head"
    rel="preload"
    as="image"
    href="/sky/milky-way-1920.avif"
    imagesrcset="/sky/milky-way-1920.avif 1920w, /sky/milky-way-2560.avif 2560w"
    imagesizes="100vw"
    fetchpriority="high"
  />
  <div class="page">
    <NightSky />
    <SiteHeader />
    <PanelDeck>
      <Panel id="hero" label="hero">
        <Hero />
      </Panel>
      <Panel id="fig-01" label="fig. 01">
        <Figure01 />
      </Panel>
      <Panel id="systems" label="selected systems">
        <SystemsList />
      </Panel>
      <Panel id="experience" label="experience">
        <ExperienceSection />
      </Panel>
      <Panel id="patents" label="patents & publications">
        <PatentsSection />
      </Panel>
      <Panel id="skills" label="skills">
        <SkillsSection />
      </Panel>
      <Panel id="contact" label="contact" emitId={false}>
        <ContactSection />
      </Panel>
    </PanelDeck>
    <SiteFooter />
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 clamp(18px, 4vw, 32px);
  }
</style>
