---
/**
 * index.astro — the single-scroll home page.
 *
 * Composes BaseLayout with the full editorial shell + content sections in
 * the locked order (01-CONTEXT.md "Page structure"). Fig. 01 renders
 * between Hero and SystemsList (Phase 2, plan 02-04).
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import Hero from "../components/Hero.astro";
import Figure01 from "../components/Figure01.astro";
import SystemsList from "../components/SystemsList.astro";
import ExperienceSection from "../components/ExperienceSection.astro";
import PatentsSection from "../components/PatentsSection.astro";
import SkillsSection from "../components/SkillsSection.astro";
import ContactSection from "../components/ContactSection.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout>
  <div class="page">
    <SiteHeader />
    <Hero />
    <Figure01 />
    <SystemsList />
    <ExperienceSection />
    <PatentsSection />
    <SkillsSection />
    <ContactSection />
    <SiteFooter />
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 clamp(18px, 4vw, 32px);
  }
</style>
